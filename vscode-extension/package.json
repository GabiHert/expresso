{
  "name": "ai-cockpit",
  "displayName": "AI Cockpit",
  "description": "Monitor and manage Claude Code tasks with real-time diff tracking",
  "version": "0.1.0",
  "publisher": "ai-cockpit",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:.ai/cockpit"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aiCockpit.showPanel",
        "title": "AI Cockpit: Show Panel"
      },
      {
        "command": "aiCockpit.refresh",
        "title": "AI Cockpit: Refresh"
      },
      {
        "command": "aiCockpit.showTaskMenu",
        "title": "AI Cockpit: Show Task Menu"
      },
      {
        "command": "aiCockpit.viewEventDiff",
        "title": "AI Cockpit: View Event Diff"
      },
      {
        "command": "aiCockpit.showClaudeChanges",
        "title": "AI Cockpit: Show Claude Changes"
      },
      {
        "command": "aiCockpit.showYourChanges",
        "title": "AI Cockpit: Show Your Changes"
      },
      {
        "command": "aiCockpit.showFullDiff",
        "title": "AI Cockpit: Show Full Diff"
      },
      {
        "command": "aiCockpit.openTaskTerminal",
        "title": "AI Cockpit: Open Task Terminal",
        "icon": "$(terminal)"
      },
      {
        "command": "aiCockpit.resumeSession",
        "title": "AI Cockpit: Resume Session",
        "icon": "$(play)"
      },
      {
        "command": "aiCockpit.focusSession",
        "title": "AI Cockpit: Focus Session",
        "icon": "$(eye)"
      },
      {
        "command": "aiCockpit.newSession",
        "title": "AI Cockpit: New Session",
        "icon": "$(add)"
      },
      {
        "command": "aiCockpit.cleanupSessions",
        "title": "AI Cockpit: Cleanup Old Sessions"
      },
      {
        "command": "aiCockpit.validateClaudePath",
        "title": "AI Cockpit: Validate Claude Path"
      },
      {
        "command": "aiCockpit.openTask",
        "title": "AI Cockpit: Open Task"
      },
      {
        "command": "aiCockpit.openWorkItem",
        "title": "AI Cockpit: Open Work Item"
      },
      {
        "command": "aiCockpit.renameSession",
        "title": "Rename Session",
        "icon": "$(edit)"
      },
      {
        "command": "aiCockpit.deleteSession",
        "title": "Delete Session",
        "icon": "$(trash)"
      },
      {
        "command": "aiCockpit.startSession",
        "title": "AI Cockpit: Start Session",
        "icon": "$(add)"
      },
      {
        "command": "aiCockpit.linkSessionToTask",
        "title": "Link to Task",
        "icon": "$(link)"
      },
      {
        "command": "aiCockpit.openFeedbackFile",
        "title": "Open Feedback",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "aiCockpit.showPlainDiff",
        "title": "Show Plain Diff",
        "icon": "$(diff)"
      },
      {
        "command": "aiCockpit.deleteTask",
        "title": "Delete Task",
        "icon": "$(trash)"
      },
      {
        "command": "aiCockpit.brewExpresso",
        "title": "AI Cockpit: Brew Expresso",
        "icon": "$(coffee)"
      },
      {
        "command": "aiCockpit.scanExpresso",
        "title": "AI Cockpit: Scan for @expresso Tags"
      },
      {
        "command": "aiCockpit.listExpresso",
        "title": "AI Cockpit: List @expresso Tags"
      },
      {
        "command": "aiCockpit.goToExpressoTag",
        "title": "AI Cockpit: Go to @expresso Tag"
      }
    ],
    "configuration": {
      "title": "AI Cockpit",
      "properties": {
        "aiCockpit.sessions.retentionDays": {
          "type": "number",
          "default": 7,
          "description": "Number of days to keep closed sessions"
        },
        "aiCockpit.sessions.autoCleanup": {
          "type": "boolean",
          "default": true,
          "description": "Automatically clean up old sessions on startup"
        },
        "aiCockpit.claude.historyPath": {
          "type": "string",
          "default": "",
          "description": "Path to Claude's history.jsonl file. Leave empty to use default (~/.claude/history.jsonl)"
        },
        "aiCockpit.claude.autoDetect": {
          "type": "boolean",
          "default": true,
          "description": "Automatically detect Claude history location"
        },
        "aiCockpit.expresso.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable @expresso tag scanning and highlighting"
        },
        "aiCockpit.expresso.showCodeLens": {
          "type": "boolean",
          "default": true,
          "description": "Show 'Brew this' button above @expresso tags"
        },
        "aiCockpit.expresso.showDecorations": {
          "type": "boolean",
          "default": true,
          "description": "Highlight @expresso tags in the editor"
        },
        "aiCockpit.expresso.fileExtensions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "ts",
            "tsx",
            "js",
            "jsx",
            "py",
            "go",
            "rs",
            "java",
            "c",
            "cpp",
            "h",
            "hpp",
            "cs",
            "rb",
            "php",
            "swift",
            "kt",
            "scala",
            "vue",
            "svelte"
          ],
          "description": "File extensions to scan for @expresso tags"
        },
        "aiCockpit.expresso.highlightKeyword": {
          "type": "boolean",
          "default": true,
          "description": "Highlight the @expresso keyword with distinct styling (bold, colored text)"
        },
        "aiCockpit.expresso.highlightCommands": {
          "type": "boolean",
          "default": true,
          "description": "Highlight valid Claude commands (/task-start, /task-work, etc.) in comments"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ai-cockpit",
          "title": "AI Cockpit",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "ai-cockpit": [
        {
          "id": "aiCockpit.tasks",
          "name": "Tasks"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "aiCockpit.startSession",
          "when": "view == aiCockpit.tasks",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "aiCockpit.openFeedbackFile",
          "when": "view == aiCockpit.tasks && viewItem == task-in_progress",
          "group": "inline@1"
        },
        {
          "command": "aiCockpit.openTaskTerminal",
          "when": "view == aiCockpit.tasks && viewItem == task-in_progress",
          "group": "inline@2"
        },
        {
          "command": "aiCockpit.openFeedbackFile",
          "when": "view == aiCockpit.tasks && viewItem == task-active",
          "group": "inline@1"
        },
        {
          "command": "aiCockpit.openTaskTerminal",
          "when": "view == aiCockpit.tasks && viewItem == task-active",
          "group": "inline@2"
        },
        {
          "command": "aiCockpit.openTaskTerminal",
          "when": "view == aiCockpit.tasks && viewItem == task-todo",
          "group": "inline"
        },
        {
          "command": "aiCockpit.openTaskTerminal",
          "when": "view == aiCockpit.tasks && viewItem == task-done",
          "group": "inline"
        },
        {
          "command": "aiCockpit.viewEventDiff",
          "when": "view == aiCockpit.tasks && viewItem == event",
          "group": "inline"
        },
        {
          "command": "aiCockpit.showPlainDiff",
          "when": "view == aiCockpit.tasks && viewItem =~ /shadow-file/",
          "group": "navigation@1"
        },
        {
          "command": "aiCockpit.showClaudeChanges",
          "when": "view == aiCockpit.tasks && viewItem =~ /shadow-file/",
          "group": "diff@1"
        },
        {
          "command": "aiCockpit.showYourChanges",
          "when": "view == aiCockpit.tasks && viewItem == shadow-file-user-modified",
          "group": "diff@2"
        },
        {
          "command": "aiCockpit.showFullDiff",
          "when": "view == aiCockpit.tasks && viewItem =~ /shadow-file/",
          "group": "diff@3"
        },
        {
          "command": "aiCockpit.focusSession",
          "when": "view == aiCockpit.tasks && viewItem == session-active",
          "group": "inline"
        },
        {
          "command": "aiCockpit.resumeSession",
          "when": "view == aiCockpit.tasks && viewItem == session-closed",
          "group": "inline"
        },
        {
          "command": "aiCockpit.newSession",
          "when": "view == aiCockpit.tasks && viewItem == sessions-section",
          "group": "inline"
        },
        {
          "command": "aiCockpit.renameSession",
          "when": "view == aiCockpit.tasks && viewItem == session-active",
          "group": "2_session@1"
        },
        {
          "command": "aiCockpit.renameSession",
          "when": "view == aiCockpit.tasks && viewItem == session-closed",
          "group": "2_session@1"
        },
        {
          "command": "aiCockpit.deleteSession",
          "when": "view == aiCockpit.tasks && viewItem == session-active",
          "group": "2_session@2"
        },
        {
          "command": "aiCockpit.deleteSession",
          "when": "view == aiCockpit.tasks && viewItem == session-closed",
          "group": "2_session@2"
        },
        {
          "command": "aiCockpit.startSession",
          "when": "view == aiCockpit.tasks && viewItem == unassigned-sessions-section",
          "group": "inline"
        },
        {
          "command": "aiCockpit.focusSession",
          "when": "view == aiCockpit.tasks && viewItem == session-active-unassigned",
          "group": "inline"
        },
        {
          "command": "aiCockpit.resumeSession",
          "when": "view == aiCockpit.tasks && viewItem == session-closed-unassigned",
          "group": "inline"
        },
        {
          "command": "aiCockpit.linkSessionToTask",
          "when": "view == aiCockpit.tasks && viewItem == session-active-unassigned",
          "group": "1_link@1"
        },
        {
          "command": "aiCockpit.linkSessionToTask",
          "when": "view == aiCockpit.tasks && viewItem == session-closed-unassigned",
          "group": "1_link@1"
        },
        {
          "command": "aiCockpit.renameSession",
          "when": "view == aiCockpit.tasks && viewItem == session-active-unassigned",
          "group": "2_session@1"
        },
        {
          "command": "aiCockpit.renameSession",
          "when": "view == aiCockpit.tasks && viewItem == session-closed-unassigned",
          "group": "2_session@1"
        },
        {
          "command": "aiCockpit.deleteSession",
          "when": "view == aiCockpit.tasks && viewItem == session-active-unassigned",
          "group": "2_session@2"
        },
        {
          "command": "aiCockpit.deleteSession",
          "when": "view == aiCockpit.tasks && viewItem == session-closed-unassigned",
          "group": "2_session@2"
        },
        {
          "command": "aiCockpit.deleteTask",
          "when": "view == aiCockpit.tasks && viewItem == task-todo",
          "group": "3_delete"
        },
        {
          "command": "aiCockpit.deleteTask",
          "when": "view == aiCockpit.tasks && viewItem == task-done",
          "group": "3_delete"
        },
        {
          "command": "aiCockpit.deleteTask",
          "when": "view == aiCockpit.tasks && viewItem == task-in_progress",
          "group": "3_delete"
        },
        {
          "command": "aiCockpit.deleteTask",
          "when": "view == aiCockpit.tasks && viewItem == task-active",
          "group": "3_delete"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/diff": "^5.2.3",
    "@types/node": "^20.0.0",
    "@types/sql.js": "^1.4.9",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@vscode/vsce": "^3.7.1",
    "diff": "^5.2.0",
    "diff2html": "^3.4.48",
    "sql.js": "^1.13.0"
  }
}
